paper/2020/file/ce1aad92b939420fc17005e5461e6f48-Paper.pdf",\n    "repo_url": "https://github.com/LeiBAI/AGCRN",\n    "datasets": ["METR-LA", "PEMS-BAY", "PEMS03", "PEMS04"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 9,\n    "abstract": "Captures fine-grained spatial and temporal correlations automatically using two adaptive modules: Node Adaptive Parameter Learning (NAPL) and Data Adaptive Graph Generation (DAGG), without requiring pre-defined graph structures.",\n    "keywords": ["traffic forecasting", "PEMS", "adaptive graph", "AGCRN", "recurrent network"]\n  },\n  {\n    "title": "Spatio-Temporal Graph Convolutional Networks: A Deep Learning Framework for Traffic Forecasting",\n    "authors": ["Bing Yu", "Haoteng Yin", "Zhanxing Zhu"],\n    "venue": "IJCAI",\n    "year": 2018,\n    "arxiv_id": "1709.04875",\n    "url": "https://arxiv.org/abs/1709.04875",\n    "pdf_url": "https://arxiv.org/pdf/1709.04875",\n    "repo_url": "https://github.com/VeritasYin/STGCN_IJCAI-18",\n    "datasets": ["PeMSD7", "BJER4"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 9,\n    "abstract": "Proposes a novel deep learning framework that formulates traffic forecasting on graphs with complete convolutional structures, combining temporal gated convolution and spectral graph convolutions.",\n    "keywords": ["traffic forecasting", "PEMS", "graph convolutional network", "STGCN", "spatio-temporal"]\n  },\n  {\n    "title": "GMAN: A Graph Multi-Attention Network for Traffic Prediction",\n    "authors": ["Chuanpan Zheng", "Xiaoliang Fan", "Cheng Wang", "Jianzhong Qi"],\n    "venue": "AAAI",\n    "year": 2020,\n    "arxiv_id": "1911.08415",\n    "url": "https://arxiv.org/abs/1911.08415",\n    "pdf_url": "https://arxiv.org/pdf/1911.08415",\n    "repo_url": "https://github.com/zhengchuanpan/GMAN",\n    "datasets": ["METR-LA", "PEMS-BAY"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 9,\n    "abstract": "Employs an encoder-decoder architecture with multiple spatio-temporal attention blocks and a transform attention layer to model direct relationships between historical and future time steps.",\n    "keywords": ["traffic forecasting", "PEMS", "graph attention", "GMAN", "multi-attention"]\n  },\n  {\n    "title": "Spatio-Temporal Meta-Graph Learning for Traffic Forecasting",\n    "authors": ["Yatao Bian", "Meiqi Zhu", "et al."],\n    "venue": "AAAI",\n    "year": 2023,\n    "arxiv_id": "2211.14701",\n    "url": "https://arxiv.org/abs/2211.14701",\n    "pdf_url": "https://arxiv.org/pdf/2211.14701",\n    "repo_url": "https://github.com/deepkashiwa20/MegaCRN",\n    "datasets": ["METR-LA", "PEMS-BAY", "EXPY-TKY"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 9,\n    "abstract": "Proposes a Meta-Graph Convolutional Recurrent Network powered by a Meta-Node Bank to disentangle spatio-temporal heterogeneity and non-stationarity in traffic streams.",\n    "keywords": ["traffic forecasting", "PEMS", "meta-graph", "MegaCRN", "spatio-temporal heterogeneity"]\n  },\n  {\n    "title": "Spatial-Temporal Synchronous Graph Convolutional Networks",\n    "authors": ["Chao Song", "Youfang Lin", "Shengnan Guo", "Huaiyu Wan"],\n    "venue": "AAAI",\n    "year": 2020,\n    "arxiv_id": "",\n    "url": "https://ojs.aaai.org/index.php/AAAI/article/view/5438",\n    "pdf_url": "https://ojs.aaai.org/index.php/AAAI/article/view/5438/5294",\n    "repo_url": "",\n    "datasets": ["PEMS03", "PEMS04", "PEMS07", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 9,\n    "abstract": "Uses localized spatial-temporal subgraph modules to independently model localized correlations in traffic data, evaluated on PEMS03, PEMS04, PEMS07, PEMS08.",\n    "keywords": ["traffic forecasting", "PEMS", "synchronous graph convolution", "STSGCN", "spatio-temporal"]\n  },\n  {\n    "title": "Spatial-Temporal Graph ODE Networks for Traffic Flow Forecasting",\n    "authors": ["Zheng Fang", "Qingqing Long", "Guojie Song", "Kunqing Xie"],\n    "venue": "KDD",\n    "year": 2021,\n    "arxiv_id": "2106.12931",\n    "url": "https://arxiv.org/abs/2106.12931",\n    "pdf_url": "https://arxiv.org/pdf/2106.12931",\n    "repo_url": "https://github.com/square-coder/STGODE",\n    "datasets": ["PEMS03", "PEMS04", "PEMS07", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 9,\n    "abstract": "Uses a tensor-based ODE to model spatial-temporal dynamics, enabling deeper networks and synchronous utilization of spatial-temporal features with a semantic adjacency matrix and temporal dilated convolution.",\n    "keywords": ["traffic forecasting", "PEMS", "ODE", "STGODE", "graph neural network"]\n  },\n  {\n    "title": "PDFormer: Propagation Delay-aware Dynamic Long-Range Transformer for Traffic Flow Prediction",\n    "authors": ["Jiawei Jiang", "Chengkai Han", "Wayne Xin Zhao", "Jingyuan Wang"],\n    "venue": "AAAI",\n    "year": 2023,\n    "arxiv_id": "",\n    "url": "https://ojs.aaai.org/index.php/AAAI/article/view/25556",\n    "pdf_url": "https://ojs.aaai.org/index.php/AAAI/article/view/25556/25328",\n    "repo_url": "https://github.com/BUAABIGSCity/PDFormer",\n    "datasets": ["METR-LA", "PEMS-BAY", "PEMS04", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 8,\n    "abstract": "A transformer model with a spatial self-attention module for dynamic spatial dependency capture and a traffic delay-aware feature transformation module that explicitly models time delay of spatial information propagation.",\n    "keywords": ["traffic forecasting", "PEMS", "transformer", "PDFormer", "propagation delay"]\n  },\n  {\n    "title": "Spatio-Temporal Self-Supervised Learning for Traffic Flow Prediction",\n    "authors": ["Jiahao Ji", "Jingyuan Wang", "Chao Huang", "Junjie Wu", "Boren Xu", "Zhenhe Wu", "Junbo Zhang", "Yu Zheng"],\n    "venue": "AAAI",\n    "year": 2023,\n    "arxiv_id": "2212.04475",\n    "url": "https://arxiv.org/abs/2212.04475",\n    "pdf_url": "https://arxiv.org/pdf/2212.04475",\n    "repo_url": "https://github.com/Echo-Ji/ST-SSL",\n    "datasets": ["PEMS03", "PEMS04", "PEMS07", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 8,\n    "abstract": "Enhances traffic representations through auxiliary self-supervised learning with adaptive augmentation at attribute and structure levels, incorporating spatial and temporal heterogeneity-aware self-supervised tasks.",\n    "keywords": ["traffic forecasting", "PEMS", "self-supervised learning", "ST-SSL", "contrastive learning"]\n  },\n  {\n    "title": "Spatial-Temporal Fusion Graph Neural Networks for Traffic Flow Forecasting",\n    "authors": ["Mengzhang Li", "Zhanxing Zhu"],\n    "venue": "AAAI",\n    "year": 2021,\n    "arxiv_id": "",\n    "url": "https://ojs.aaai.org/index.php/AAAI/article/view/16542",\n    "pdf_url": "https://ojs.aaai.org/index.php/AAAI/article/view/16542/16349",\n    "repo_url": "https://github.com/MengzhangLI/STFGNN",\n    "datasets": ["PEMS03", "PEMS04", "PEMS07", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 8,\n    "abstract": "Introduces a spatial-temporal fusion graph that integrates spatial and temporal connections to capture both local and non-local dependencies in traffic flow.",\n    "keywords": ["traffic forecasting", "PEMS", "fusion graph", "STFGNN", "spatio-temporal"]\n  },\n  {\n    "title": "Attention Based Spatial-Temporal Graph Convolutional Networks for Traffic Flow Forecasting",\n    "authors": ["Shengnan Guo", "Youfang Lin", "Ning Feng", "Chao Song", "Huaiyu Wan"],\n    "venue": "AAAI",\n    "year": 2019,\n    "arxiv_id": "",\n    "url": "https://ojs.aaai.org/index.php/AAAI/article/view/3881",\n    "pdf_url": "https://ojs.aaai.org/index.php/AAAI/article/view/3881/3759",\n    "repo_url": "https://github.com/Davidham3/ASTGCN",\n    "datasets": ["PEMS04", "PEMS07", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 8,\n    "abstract": "Introduces a spatial-temporal attention mechanism over three independent components (recent, daily-periodic, weekly-periodic) to capture dynamic spatial-temporal correlations in PEMS traffic flow data.",\n    "keywords": ["traffic forecasting", "PEMS", "attention", "ASTGCN", "graph convolution"]\n  },\n  {\n    "title": "Connecting the Dots: Multivariate Time Series Forecasting with Graph Neural Networks",\n    "authors": ["Zonghan Wu", "Shirui Pan", "Guodong Long", "Jing Jiang", "Xiaojun Chang", "Chengqi Zhang"],\n    "venue": "KDD",\n    "year": 2020,\n    "arxiv_id": "2005.11650",\n    "url": "https://arxiv.org/abs/2005.11650",\n    "pdf_url": "https://arxiv.org/pdf/2005.11650",\n    "repo_url": "https://github.com/nnzhan/MTGNN",\n    "datasets": ["METR-LA", "PEMS-BAY"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 8,\n    "abstract": "A general GNN framework for multivariate time series that automatically extracts uni-directed relations among variables through a graph learning module, integrating mix-hop propagation and dilated inception layers end-to-end.",\n    "keywords": ["traffic forecasting", "PEMS", "multivariate time series", "MTGNN", "graph learning"]\n  },\n  {\n    "title": "iTransformer: Inverted Transformers Are Effective for Time Series Forecasting",\n    "authors": ["Yong Liu", "Tengge Hu", "Haoran Zhang", "Ling Chen", "Junlong Liao", "Guihua Wen", "Zhichao Huang", "Naiqi Li", "Jianmin Wang", "Mingsheng Long"],\n    "venue": "ICLR",\n    "year": 2024,\n    "arxiv_id": "2310.06625",\n    "url": "https://arxiv.org/abs/2310.06625",\n    "pdf_url": "https://arxiv.org/pdf/2310.06625",\n    "repo_url": "https://github.com/thuml/iTransformer",\n    "datasets": ["METR-LA", "PEMS-BAY", "PEMS04", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 8,\n    "abstract": "Re-purposes the Transformer by applying attention and feed-forward networks on inverted dimensions, treating each variate as a token. Achieves state-of-the-art on multiple datasets including PEMS traffic benchmarks.",\n    "keywords": ["time series forecasting", "PEMS", "transformer", "iTransformer", "inverted attention"]\n  },\n  {\n    "title": "FreTS: Frequency-domain MLPs are More Effective Learners in Time Series Forecasting",\n    "authors": ["Kun Yi", "Qi Zhang", "Wei Fan", "Shoujin Wang", "Pengyang Wang", "Hui He", "Ning An", "Defu Lian", "Longbing Cao", "Zhendong Niu"],\n    "venue": "NeurIPS",\n    "year": 2023,\n    "arxiv_id": "2311.06184",\n    "url": "https://arxiv.org/abs/2311.06184",\n    "pdf_url": "https://arxiv.org/pdf/2311.06184",\n    "repo_url": "https://github.com/aikunyi/FreTS",\n    "datasets": ["PEMS04", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 8,\n    "abstract": "Proposes frequency-domain MLP models learning in the frequency domain for global view and energy compaction, demonstrating consistent superiority across 13 benchmarks including short-term traffic datasets.",\n    "keywords": ["time series forecasting", "PEMS", "frequency domain", "FreTS", "MLP"]\n  },\n  {\n    "title": "Spatio-Temporal Adaptive Embedding Makes Vanilla Transformer SOTA for Traffic Forecasting",\n    "authors": ["Hangchen Liu", "Zheng Dong", "Renhe Jiang", "Jiewen Deng", "Jinliang Deng", "Quanjun Chen", "Xuan Song"],\n    "venue": "CIKM",\n    "year": 2023,\n    "arxiv_id": "2308.10425",\n    "url": "https://arxiv.org/abs/2308.10425",\n    "pdf_url": "https://arxiv.org/pdf/2308.10425",\n    "repo_url": "https://github.com/XDZhelheim/STAEformer",\n    "datasets": ["METR-LA", "PEMS-BAY", "PEMS03", "PEMS04", "PEMS07", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 8,\n    "abstract": "Introduces a spatio-temporal adaptive embedding component to vanilla Transformers enabling state-of-the-art traffic forecasting without complex architectural modifications.",\n    "keywords": ["traffic forecasting", "PEMS", "transformer", "STAEformer", "adaptive embedding"]\n  },\n  {\n    "title": "Spectral Temporal Graph Neural Network for Multivariate Time-Series Forecasting",\n    "authors": ["Defu Cao", "Yujing Wang", "Juanyong Duan", "Ce Zhang", "Xia Zhu", "Congrui Huang", "Yunhai Tong", "Bixiong Xu", "Jing Bai", "Jie Tong", "Qi Zhang"],\n    "venue": "NeurIPS",\n    "year": 2020,\n    "arxiv_id": "",\n    "url": "https://proceedings.neurips.cc/paper/2020/hash/cdf6581cb7aca4b7e19ef136c6e601a5-Abstract.html",\n    "pdf_url": "https://proceedings.neurips.cc/paper/2020/file/cdf6581cb7aca4b7e19ef136c6e601a5-Paper.pdf",\n    "repo_url": "https://github.com/microsoft/StemGNN",\n    "datasets": ["METR-LA", "PEMS-BAY"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 7,\n    "abstract": "Incorporates inter-series correlations and intra-series temporal patterns using Graph Fourier Transform (GFT) and Discrete Fourier Transform (DFT) in the spectral domain for multivariate time-series forecasting.",\n    "keywords": ["time series forecasting", "PEMS", "spectral graph", "StemGNN", "Fourier transform"]\n  },\n  {\n    "title": "Spatio-Temporal Pivotal Graph Neural Networks for Traffic Flow Forecasting",\n    "authors": ["Weiyang Kong", "Ziyu Guo", "Yubao Liu"],\n    "venue": "AAAI",\n    "year": 2024,\n    "arxiv_id": "",\n    "url": "https://ojs.aaai.org/index.php/AAAI/article/view/28707",\n    "pdf_url": "https://ojs.aaai.org/index.php/AAAI/article/view/28707/29369",\n    "repo_url": "",\n    "datasets": ["PEMS03", "PEMS04", "PEMS07", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 7,\n    "abstract": "Identifies critical pivotal nodes with extensive connections in traffic networks and employs a dedicated pivotal graph convolution module within a parallel framework capturing spatio-temporal features.",\n    "keywords": ["traffic forecasting", "PEMS", "pivotal nodes", "STPGNN", "graph neural network"]\n  },\n  {\n    "title": "Graph for Time Series",\n    "authors": ["Chao Shang", "Jie Chen", "Jinbo Bi"],\n    "venue": "ICLR",\n    "year": 2021,\n    "arxiv_id": "2101.06861",\n    "url": "https://arxiv.org/abs/2101.06861",\n    "pdf_url": "https://arxiv.org/pdf/2101.06861",\n    "repo_url": "https://github.com/chaoshangcs/GTS",\n    "datasets": ["METR-LA", "PEMS-BAY"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 7,\n    "abstract": "Proposes a method for jointly learning graph structure and time series forecasting model end-to-end, showing that learning a hidden graph structure from data improves traffic forecasting performance significantly.",\n    "keywords": ["traffic forecasting", "PEMS", "graph structure learning", "GTS", "time series"]\n  },\n  {\n    "title": "Are Transformers Effective for Time Series Forecasting?",\n    "authors": ["Ailing Zeng", "Muxi Chen", "Lei Zhang", "Qiang Xu"],\n    "venue": "AAAI",\n    "year": 2023,\n    "arxiv_id": "2205.13504",\n    "url": "https://arxiv.org/abs/2205.13504",\n    "pdf_url": "https://arxiv.org/pdf/2205.13504",\n    "repo_url": "https://github.com/cure-lab/LTSF-Linear",\n    "datasets": ["ETTh1", "ETTh2", "ETTm1", "ETTm2", "Weather", "Exchange-Rate", "ILI", "Traffic"],\n    "metrics": ["MAE", "MSE", "RMSE", "MAPE"],\n    "relevance_score": 7,\n    "abstract": "Demonstrates that simple one-layer linear models (DLinear, NLinear) consistently outperform sophisticated Transformer-based forecasters, challenging the paradigm for time-series including traffic benchmarks.",\n    "keywords": ["time series forecasting", "transformer", "DLinear", "linear model", "benchmark"]\n  },\n  {\n    "title": "Spatial-Temporal Identity: A Simple yet Effective Baseline for Multivariate Time Series Forecasting",\n    "authors": ["Zezhi Shao", "Zhao Zhang", "Fei Wang", "Wei Wei", "Yongjun Xu"],\n    "venue": "CIKM",\n    "year": 2022,\n    "arxiv_id": "2208.05233",\n    "url": "https://arxiv.org/abs/2208.05233",\n    "pdf_url": "https://arxiv.org/pdf/2208.05233",\n    "repo_url": "https://github.com/zezhishao/STID",\n    "datasets": ["METR-LA", "PEMS-BAY", "PEMS03", "PEMS04", "PEMS07", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 7,\n    "abstract": "Addresses sample indistinguishability in spatial and temporal dimensions by attaching Spatial and Temporal IDentity information to simple MLP models, achieving comparable or superior performance to complex STGNNs.",\n    "keywords": ["traffic forecasting", "PEMS", "identity embedding", "STID", "MLP baseline"]\n  },\n  {\n    "title": "Decoupled Dynamic Spatial-Temporal Graph Neural Network for Traffic Forecasting",\n    "authors": ["Zezhi Shao", "Zhao Zhang", "Wei Wei", "Fei Wang", "Yongjun Xu", "Xin Cao"],\n    "venue": "VLDB",\n    "year": 2022,\n    "arxiv_id": "2206.09112",\n    "url": "https://arxiv.org/abs/2206.09112",\n    "pdf_url": "https://arxiv.org/pdf/2206.09112",\n    "repo_url": "https://github.com/zezhishao/D2STGNN",\n    "datasets": ["METR-LA", "PEMS-BAY", "PEMS04", "PEMS08"],\n    "metrics": ["MAE", "RMSE", "MAPE"],\n    "relevance_score": 7,\n    "abstract": "Proposes a Decoupled Spatial-Temporal Framework separating traffic signals into diffusion and inherent components, with a dynamic graph learning module for capturing dynamic network characteristics.",\n    "keywords": ["traffic forecasting", "PEMS", "decoupled", "D2STGNN", "dynamic graph"]\n  },\n  {\n    "title": "Autoformer: Decomposition Transformers with Auto-Correlation for Long-Term Series Forecasting",\n    "authors": ["Haixu Wu", "Jiehui Xu", "Jianmin Wang", "Mingsheng Long"],\n    "venue": "NeurIPS",\n    "year": 2021,\n    "arxiv_id": "2106.13008",\n    "url": "https://arxiv.org/abs/2106.13008",\n    "pdf_url": "https://arxiv.org/pdf/2106.13008",\n    "repo_url": "https://github.com/thuml/Autoformer",\n    "datasets": ["ETT", "Exchange", "Weather", "ILI", "Traffic"],\n    "metrics": ["MAE", "MSE"],\n    "relevance_score": 6,\n    "abstract": "Introduces a decomposition architecture with Auto-Cor