{
  "model": "ProbETA",
  "task": "eta",

  "embedding_dim": 64,
  "dropout_mean": 0.9,
  "dropout_cov": 0.3,
  "hidden_mean_1": 72,
  "hidden_mean_2": 64,
  "hidden_mean_3": 32,
  "hidden_cov_1": 32,
  "hidden_cov_2": 16,
  "use_device_similarity": true,
  "loss_type": "nll",
  "enable_time_dis": true,
  "cov_reg_weight": 0.1,

  "max_epoch": 100,
  "batch_size": 128,
  "learner": "adam",
  "learning_rate": 0.001,
  "lr_decay": true,
  "lr_decay_ratio": 0.6,
  "lr_scheduler": "reducelronplateau",
  "lr_patience": 10,
  "clip_grad_norm": false,
  "use_early_stop": true,
  "patience": 20,
  "weight_decay": 0.0001,
  "train_loss": "none"
}
