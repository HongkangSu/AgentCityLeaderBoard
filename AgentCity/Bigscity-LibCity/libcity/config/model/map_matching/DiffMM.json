{
    "model_name": "DiffMM",
    "dataset_class": "DiffMMDataset",
    "hid_dim": 256,
    "num_units": 512,
    "transformer_layers": 2,
    "depth": 2,
    "timesteps": 2,
    "samplingsteps": 1,
    "dropout": 0.1,
    "bootstrap_every": 8,
    "num_heads": 4,
    "beta_schedule": "cosine",
    "optimizer": "AdamW",
    "learning_rate": 0.001,
    "weight_decay": 1e-6,
    "lr_scheduler": "none",
    "batch_size": 16,
    "max_epoch": 30,
    "clip_grad_norm": 1.0,
    "evaluate_method": "segment",
    "num_cands": 10,
    "cand_search_radius": 100,
    "max_seq_len": 100,
    "min_seq_len": 5,
    "train_rate": 0.7,
    "eval_rate": 0.15
}
