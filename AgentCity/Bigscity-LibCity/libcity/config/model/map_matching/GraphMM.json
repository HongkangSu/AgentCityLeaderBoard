{
  "model_name": "GraphMM",

  "emb_dim": 256,
  "layer": 4,
  "topn": 5,
  "neg_nums": 800,
  "gamma": 10000,
  "atten_flag": true,
  "drop_prob": 0.5,
  "bi": true,
  "use_crf": true,
  "tf_ratio": 0.5,
  "road_feature_dim": 28,
  "trace_feature_dim": 4,
  "gin_depth": 3,
  "gin_mlp_layers": 2,
  "digcn_depth": 2,

  "batch_size": 32,
  "train_batch_size": 32,
  "eval_batch_size": 32,
  "learning_rate": 0.0001,
  "weight_decay": 1e-8,
  "max_epoch": 200,
  "learner": "adam",
  "lr_scheduler": "step",
  "lr_decay": 0.5,
  "lr_decay_ratio": 0.5,
  "lr_step_size": 30,
  "clip_grad_norm": true,
  "max_grad_norm": 5.0,

  "use_early_stop": true,
  "patience": 10,
  "log_every": 0.9,
  "saved": true,
  "save_mode": "best",
  "train_loss": "none",

  "metrics": ["RMF", "AN", "AL"],

  "cache_dataset": true,
  "num_workers": 0,
  "load_best_epoch": true,

  "debug": false,
  "hyper_tune": false,

  "dataset_class": "DeepMapMatchingDataset",
  "executor": "DeepMapMatchingExecutor",
  "evaluator": "MapMatchingEvaluator"
}
