{
  "src_loc_emb_dim": 256,
  "src_tim_emb_dim": 64,
  "trg_seg_emb_dim": 256,
  "src_hidden_dim": 512,
  "trg_hidden_dim": 512,
  "bidirectional": true,
  "nlayers_src": 2,
  "dropout": 0.5,
  "time_encoding": "NoEncoding",
  "rnn_type": "LSTM",
  "attn_type": "dot",
  "batch_size": 128,
  "learning_rate": 0.001,
  "max_epoch": 100,
  "optimizer": "adam",
  "input_max_len": 40,
  "output_max_len": 54,
  "learner": "adam",
  "lr_decay": 0.5,
  "lr_step": 3,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.1,
  "steps": [20, 40, 60],
  "clip_grad_norm": true,
  "max_grad_norm": 5.0,
  "clip": 5.0,
  "use_early_stop": true,
  "patience": 10,
  "log_every": 1,
  "saved": true,
  "save_mode": "best",
  "train_loss": "CrossEntropyLoss",
  "L2": 0.0001,
  "early_stop_lr": 1e-6,
  "load_best_epoch": true,
  "debug": false,
  "hyper_tune": false,
  "schedule_threshold": 0.001,
  "metrics": ["RMF", "AN", "AL"],

  "grid_size": 0.001,
  "train_rate": 0.7,
  "eval_rate": 0.15,
  "cache_dataset": true,
  "num_workers": 0,

  "enable_segmentation": true,
  "segment_window_src": 100,
  "segment_window_trg": 54,
  "segment_stride_ratio": 0.5
}
