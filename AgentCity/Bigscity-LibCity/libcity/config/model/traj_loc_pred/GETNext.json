{
    "poi_embed_dim": 128,
    "user_embed_dim": 128,
    "time_embed_dim": 32,
    "cat_embed_dim": 32,
    "gcn_nhid": [32, 64],
    "gcn_dropout": 0.3,
    "transformer_nhid": 1024,
    "transformer_nlayers": 2,
    "transformer_nhead": 2,
    "transformer_dropout": 0.3,
    "node_attn_nhid": 128,
    "time_loss_weight": 10.0,
    "time_activation": "sin",
    "use_graph_attn": true,
    "max_session_len": 100,
    "cut_method": "fixed_length",
    "window_size": 100,
    "batch_size": 50,
    "learning_rate": 0.001,
    "max_epoch": 30,
    "L2": 5e-4,
    "clip": 5.0,
    "optimizer": "Adam",
    "lr_scheduler": "ReduceLROnPlateau",
    "lr_scheduler_patience": 5,
    "lr_scheduler_factor": 0.5,
    "lr_step": 5,
    "lr_decay": 0.1
}
