{
    "model": "TRMMA",
    "task": "traj_loc_pred",

    "hid_dim": 256,
    "id_emb_dim": 256,
    "transformer_layers": 2,
    "heads": 4,
    "dropout": 0.1,

    "pro_features_flag": true,
    "pro_input_dim": 48,
    "pro_output_dim": 8,
    "learn_pos": true,
    "da_route_flag": true,
    "srcseg_flag": false,
    "rid_feats_flag": true,
    "rid_fea_dim": 18,

    "dest_type": 1,
    "rate_flag": false,
    "prog_flag": false,

    "lambda1": 10.0,
    "lambda2": 5.0,
    "teacher_forcing_ratio": 1.0,
    "keep_ratio": 0.125,

    "batch_size": 4,
    "learning_rate": 0.001,
    "max_epoch": 30,
    "epochs": 30,
    "optimizer": "adam",
    "weight_decay": 0.0001,
    "lr_scheduler": "exponentiallr",
    "lr_decay": 0.8,
    "lr_step": 5,
    "clip_grad_norm": true,
    "max_grad_norm": 1.0,

    "use_early_stop": true,
    "patience": 10,
    "log_every": 1,
    "saved": true,
    "save_mode": "best",
    "load_best_epoch": true,
    "hyper_tune": false,

    "candi_size": 50,
    "max_input_length": 500,
    "history_type": "splice",
    "evaluate_method": "popularity"
}
