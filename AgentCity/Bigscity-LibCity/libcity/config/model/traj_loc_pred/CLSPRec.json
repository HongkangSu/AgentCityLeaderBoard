{
    "model": "CLSPRec",
    "f_embed_size": 60,
    "num_encoder_layers": 1,
    "num_lstm_layers": 1,
    "num_heads": 1,
    "forward_expansion": 4,
    "dropout_p": 0.2,
    "neg_weight": 1.0,
    "temperature": 0.07,
    "mask_prop": 0.1,
    "enable_ssl": true,
    "enable_random_mask": true,
    "neg_sample_count": 5,
    "sample_day_length": 14,
    "batch_size": 256,
    "learning_rate": 0.0001,
    "max_epoch": 25,
    "optimizer": "adam",
    "lr_step": 5,
    "lr_decay": 0.9,
    "L2": 0.0,
    "clip": 5.0,
    "window_size": 100,
    "cut_method": "fixed_length"
}
