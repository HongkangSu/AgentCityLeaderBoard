{
  "model": "DeepMM",
  "task": "traj_loc_pred",

  "src_loc_emb_dim": 256,
  "src_tim_emb_dim": 64,
  "trg_seg_emb_dim": 256,
  "src_hidden_dim": 512,
  "trg_hidden_dim": 512,
  "bidirectional": true,
  "nlayers_src": 2,
  "nlayers_trg": 1,
  "dropout": 0.5,
  "time_encoding": "NoEncoding",
  "rnn_type": "LSTM",
  "attn_type": "dot",
  "teacher_forcing_ratio": 1.0,
  "max_src_length": 40,
  "max_trg_length": 54,

  "batch_size": 128,
  "learning_rate": 0.001,
  "max_epoch": 100,
  "optimizer": "adam",
  "weight_decay": 0.0001,
  "lr_scheduler": "exponentiallr",
  "lr_decay": 0.5,
  "lr_step": 5,
  "clip_grad_norm": true,
  "max_grad_norm": 5.0,
  "use_early_stop": true,
  "patience": 3,
  "log_every": 1,
  "saved": true,
  "save_mode": "best",
  "load_best_epoch": true,
  "hyper_tune": false,

  "input_max_len": 40,
  "output_max_len": 54,
  "grid_size": 0.001,
  "train_rate": 0.7,
  "eval_rate": 0.15,
  "cache_dataset": true,
  "num_workers": 0,

  "enable_segmentation": true,
  "segment_window_src": 40,
  "segment_window_trg": 54,
  "segment_stride_ratio": 0.5,
  "min_segment_length": 10
}
