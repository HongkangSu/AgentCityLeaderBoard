{
    "model_name": "JGRM",
    "route_max_len": 100,
    "road_feat_num": 1,
    "road_embed_size": 128,
    "gps_feat_num": 8,
    "gps_embed_size": 128,
    "route_embed_size": 128,
    "hidden_size": 256,
    "drop_edge_rate": 0.1,
    "drop_route_rate": 0.1,
    "drop_road_rate": 0.1,
    "mask_length": 2,
    "mask_prob": 0.2,
    "tau": 0.07,
    "mode": "x",
    "mlm_loss_weight": 1.0,
    "match_loss_weight": 2.0,
    "route_transformer_layers": 4,
    "route_transformer_heads": 8,
    "shared_transformer_layers": 2,
    "shared_transformer_heads": 4,
    "queue_size": 2048,
    "optimizer": "AdamW",
    "learning_rate": 0.0005,
    "weight_decay": 1e-6,
    "lr_scheduler": "linear_warmup",
    "warmup_step": 1000,
    "batch_size": 64,
    "epochs": 100,
    "output_dim": 1,
    "embed_dim": 32
}
