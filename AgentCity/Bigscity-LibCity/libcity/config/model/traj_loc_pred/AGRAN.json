{
    "model": "AGRAN",
    "hidden_units": 64,
    "num_blocks": 3,
    "num_heads": 2,
    "dropout_rate": 0.3,
    "maxlen": 50,
    "time_span": 256,
    "dis_span": 256,
    "l2_emb": 0.0001,
    "kl_reg": 1.0,
    "gcn_layers": 4,
    "top_k_neighbors": 100,
    "chunk_size": 1000,
    "num_neg_samples": 1000,
    "agcn_refresh_epochs": 1,
    "cut_method": "fixed_length",
    "window_size": 50,
    "batch_size": 128,
    "learning_rate": 0.001,
    "max_epoch": 50,
    "clip": 5.0,
    "optimizer": "adam",
    "lr_scheduler": "ReduceLROnPlateau",
    "lr_scheduler_factor": 0.1,
    "lr_decay": 0.1,
    "lr_step": 5,
    "weight_decay": 0.0001,
    "short_traj_thres": 2
}
