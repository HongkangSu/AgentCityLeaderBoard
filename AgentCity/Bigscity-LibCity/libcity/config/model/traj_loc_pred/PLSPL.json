{
    "model": "PLSPL",
    "hidden_size": 128,
    "num_layers": 1,
    "embed_poi": 300,
    "embed_cat": 100,
    "embed_user": 50,
    "embed_hour": 20,
    "embed_week": 7,
    "dropout": 0.5,
    "seq_len": 19,
    "learning_rate": 0.001,
    "max_epoch": 25,
    "batch_size": 32,
    "optimizer": "adam",
    "lr_scheduler": "StepLR",
    "lr_step": 5,
    "lr_decay": 0.5,
    "weight_decay": 0.0001,
    "clip": 5.0,
    "log_batch": 1,
    "learner": "adam",
    "step_size": 10,
    "lr_epsilon": 1e-8,
    "lr_momentum": 0,
    "lr_alpha": 0.99,
    "lr_beta1": 0.9,
    "lr_beta2": 0.999,
    "lr_T_max": 30,
    "lr_eta_min": 0,
    "lr_patience": 10,
    "lr_threshold": 0.0001
}
