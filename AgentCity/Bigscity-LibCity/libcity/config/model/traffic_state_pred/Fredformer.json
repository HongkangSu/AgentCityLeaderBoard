{
  "cf_dim": 48,
  "cf_depth": 2,
  "cf_heads": 6,
  "cf_mlp": 256,
  "cf_head_dim": 16,
  "cf_drop": 0.3,
  "d_model": 128,
  "patch_len": 4,
  "stride": 2,
  "dropout": 0.2,
  "head_dropout": 0.0,
  "revin": 1,
  "affine": 1,
  "subtract_last": 0,
  "use_nys": 0,
  "individual": 0,
  "ablation": 0,
  "mlp_hidden": 256,
  "mlp_drop": 0.1,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,

  "max_epoch": 100,
  "batch_size": 128,
  "learner": "adam",
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "lr_epsilon": 1e-8,
  "lr_decay": true,
  "lr_scheduler": "cosinelr",
  "clip_grad_norm": false,
  "use_early_stop": true,
  "patience": 10
}
