{
  "seq_len": 864,
  "patch_size": 12,
  "embed_dim": 96,
  "num_heads": 4,
  "mlp_ratio": 4,
  "dropout": 0.1,
  "mask_ratio": 0.25,
  "encoder_depth": 4,
  "decoder_depth": 1,

  "mode": "pre-train",
  "spatial": false,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,

  "batch_size": 8,
  "max_epoch": 200,
  "learner": "adam",
  "learning_rate": 0.0005,
  "weight_decay": 0.0,
  "lr_epsilon": 1e-08,
  "lr_betas": [0.9, 0.95],
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.5,
  "milestones": [50],
  "clip_grad_norm": true,
  "max_grad_norm": 5.0,
  "use_early_stop": false,
  "patience": 20
}
