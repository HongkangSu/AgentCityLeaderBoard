{
  "model": "STHSepNet",

  "_comment_model_architecture": "STHSepNet model architecture parameters",
  "hidden_dim": 64,
  "d_model": 32,
  "d_ff": 32,
  "n_heads": 4,
  "num_layers": 2,
  "dropout": 0.1,

  "_comment_graph_parameters": "Graph and hypergraph construction parameters",
  "gcn_true": true,
  "hgcn_true": true,
  "hgat_true": false,
  "buildA_true": true,
  "buildH_true": true,
  "gcn_depth": 2,
  "adaptive_hyperhgnn": "hgcn",
  "scale_hyperedges": 10,
  "temporl_true": true,
  "static": false,

  "_comment_fusion_parameters": "Fusion gate parameters (learnable)",
  "alpha": 0.1,
  "beta": 0.3,
  "gamma": 0.5,
  "theta": 0.2,
  "fusion_gate": "adaptive",

  "_comment_window_settings": "Input and output window settings",
  "input_window": 12,
  "output_window": 12,

  "_comment_data_settings": "Data preprocessing settings",
  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,
  "bidir_adj_mx": false,

  "_comment_training_settings": "Training configuration",
  "max_epoch": 100,
  "batch_size": 32,
  "learner": "adam",
  "learning_rate": 0.0001,
  "weight_decay": 0.0001,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.1,
  "steps": [50, 80],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 15,

  "_comment_evaluation": "Evaluation settings",
  "metrics": ["MAE", "RMSE", "MAPE"],
  "log_every": 1
}
