{
  "hidden_dim": 64,
  "num_layers": 3,
  "dropout": 0.1,
  "num_heads": 8,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": true,
  "batch_size": 4,
  "max_epoch": 100,
  "learner": "adam",
  "learning_rate": 0.001,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.5,
  "steps": [50, 75],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 15,
  "log_every": 1,
  "saved": true,
  "save_mode": "best",
  "monitor_metric": "MAE"
}
