{
  "d_model": 512,
  "n_heads": 8,
  "e_layers": 4,
  "d_ff": 2048,
  "dropout": 0.1,
  "activation": "relu",
  "output_attention": false,
  "use_norm": true,
  "covariate": false,
  "flash_attention": false,
  "input_token_len": 1,
  "output_token_len": 1,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,

  "max_epoch": 100,
  "learner": "adam",
  "learning_rate": 0.001,
  "lr_decay": true,
  "lr_scheduler": "cosinelr",
  "lr_decay_ratio": 0.5,
  "lr_eta_min": 1e-6,
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 15
}
