{
  "input_window": 12,
  "output_window": 12,
  "d_model": 512,
  "use_norm": true,
  "emb_dropout": 0.1,
  "decom_type": "STD",
  "std_kernel": 25,
  "rank": 8,
  "node_dim": 32,
  "e_layers": 2,
  "d_state": 32,
  "d_conv": 2,
  "expand": 1,
  "d_ff": 256,
  "ffn_dropout": 0.1,
  "ffn_activation": "gelu",
  "ds_type": "avg",
  "ds_layers": 2,
  "ds_window": 2,
  "initial_tre_w": 0.5,
  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,
  "max_epoch": 100,
  "batch_size": 64,
  "learner": "adam",
  "learning_rate": 0.001,
  "weight_decay": 0.0,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.5,
  "steps": [20, 30, 40, 50],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": false
}
