{
  "input_window": 12,
  "output_window": 12,
  "input_dim": 1,
  "embed_dim": 64,
  "num_layer": 2,
  "node_dim": 64,
  "temp_dim_tid": 64,
  "temp_dim_diw": 64,
  "if_spatial": true,
  "if_time_in_day": true,
  "if_day_in_week": true,
  "if_dne": true,
  "mid_dim": 128,
  "dne_act": "softmax",
  "info_beta": 0.0001,
  "n_sample": 1,
  "n_sample_avg": 12,
  "use_difficulty_weighting": false,
  "use_ib_loss": true,
  "scaler": "standard",
  "load_external": true,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": true,
  "time_intervals": 300,
  "max_epoch": 300,
  "learner": "adam",
