{
  "d_model": 32,
  "num_layer": 2,
  "if_rel": false,
  "res_conn": true,
  "dropout": 0.2,

  "scaler": "standard",
  "load_external": true,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": true,

  "max_epoch": 100,
  "learner": "adam",
  "learning_rate": 0.0005,
  "weight_decay": 0.0005,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.5,
  "steps": [1, 50],
  "clip_grad_norm": true,
  "max_grad_norm": 5.0,
  "use_early_stop": true,
  "patience": 10
}
