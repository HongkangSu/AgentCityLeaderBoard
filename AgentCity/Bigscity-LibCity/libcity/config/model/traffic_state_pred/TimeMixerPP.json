{
  "d_model": 16,
  "d_ff": 32,
  "e_layers": 2,
  "down_sampling_layers": 3,
  "down_sampling_window": 2,
  "down_sampling_method": "avg",
  "decomp_method": "moving_avg",
  "moving_avg": 25,
  "top_k": 5,
  "channel_independence": 1,
  "use_norm": 1,
  "dropout": 0.1,
  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,
  "max_epoch": 100,
  "learner": "adam",
  "learning_rate": 0.01,
  "lr_decay": true,
  "lr_scheduler": "cosineannealinglr",
  "lr_T_max": 100,
  "lr_eta_min": 1e-5,
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 10,
  "input_window": 96,
  "output_window": 96,
  "batch_size": 16
