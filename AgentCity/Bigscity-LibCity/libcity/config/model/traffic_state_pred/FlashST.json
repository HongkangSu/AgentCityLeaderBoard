{
  "embed_dim": 32,
  "hidden_dim": 64,
  "num_layer": 3,
  "node_dim": 32,
  "temp_dim_tid": 32,
  "temp_dim_diw": 32,
  "input_base_dim": 1,
  "if_time_in_day": true,
  "if_day_in_week": true,
  "if_spatial": true,
  "use_gnn": true,
  "dropout": 0.1,
  "scaler": "standard",
  "load_external": true,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": true,
  "max_epoch": 100,
  "batch_size": 64,
  "learner": "adam",
  "learning_rate": 0.003,
  "lr_decay": true,
  "lr_decay_ratio": 0.3,
  "lr_scheduler": "multisteplr",
  "steps": [70, 160, 240],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 25,
  "input_window": 12,
  "output_window": 12
}
