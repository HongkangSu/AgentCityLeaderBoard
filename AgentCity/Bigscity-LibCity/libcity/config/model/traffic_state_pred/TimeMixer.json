{
  "d_model": 16,
  "d_ff": 32,
  "e_layers": 2,
  "down_sampling_layers": 3,
  "down_sampling_window": 2,
  "down_sampling_method": "avg",
  "decomp_method": "moving_avg",
  "channel_independence": 1,
  "moving_avg": 25,
  "dropout": 0.1,
  "use_norm": 1,
  "top_k": 5,
  "label_len": 0,
  "freq": "h",
  "embed": "timeF",
  "use_future_temporal_feature": false,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,

  "max_epoch": 100,
  "batch_size": 64,
  "learner": "adam",
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "lr_epsilon": 1e-8,
  "lr_decay": true,
  "lr_scheduler": "cosinelr",
  "clip_grad_norm": false,
  "use_early_stop": false
}