{
  "embed_dim": 32,
  "node_dim": 32,
  "temp_dim_tid": 32,
  "temp_dim_diw": 32,
  "num_layer": 3,
  "dropout": 0.15,
  "if_T_i_D": true,
  "if_D_i_W": true,
  "if_spatial": true,
  "if_dne": true,
  "mid_dim": 32,
  "dne_act": "softplus",
  "beta_ib": 0.001,
  "n_sample_train": 1,
  "n_sample_predict": 12,
  "scaler": "standard",
  "load_external": true,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": true,
  "max_epoch": 200,
  "learner": "adam",
  "learning_rate": 0.001,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.5,
  "steps": [50, 100, 150],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 20,
  "input_window": 12,
  "output_window": 12
}
