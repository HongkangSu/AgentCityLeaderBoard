{
  "model": "BigST",
  "task": "traffic_state_pred",

  "input_window": 12,
  "output_window": 12,

  "num_layers": 1,
  "hid_dim": 32,
  "node_dim": 32,
  "time_dim": 32,
  "tau": 1.0,
  "random_feature_dim": 64,
  "dropout": 0.1,

  "use_residual": true,
  "use_bn": true,
  "use_spatial": false,
  "use_long": false,

  "time_num": 288,
  "week_num": 7,

  "scaler": "standard",
  "load_external": true,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": true,

  "max_epoch": 100,
  "batch_size": 64,
  "learner": "adam",
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.5,
  "steps": [50, 80],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 20
}
