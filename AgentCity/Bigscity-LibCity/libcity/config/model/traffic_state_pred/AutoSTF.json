{
  "model": "AutoSTF",
  "dataset": "METR_LA",
  "task": "traffic_state_pred",

  "hidden_channels": 32,
  "end_channels": 512,
  "num_mlp_layers": 2,
  "num_linear_layers": 2,
  "num_hop": 2,
  "num_att_layers": 2,
  "num_temporal_search_node": 3,
  "temporal_operations": ["Zero", "Identity", "Informer", "DCC_2"],
  "spatial_operations": ["Zero", "Identity", "GNN_fixed", "GNN_adap", "GNN_att"],
  "layer_names": ["TemporalSearch", "SpatialSearch"],
  "scale_list": [1, 2, 3, 4],
  "IsUseLinear": true,
  "mode": "ONE_PATH_FIXED",

  "input_window": 12,
  "output_window": 12,

  "scaler": "standard",
  "load_external": true,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": true,

  "max_epoch": 100,
  "batch_size": 64,
  "learner": "adam",
  "learning_rate": 0.001,
  "weight_decay": 1e-05,
  "lr_epsilon": 1e-08,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.5,
  "steps": [50, 80],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 20
}
