{
  "dropout": 0.0,
  "rank": 6,
  "gcn_hidden_channel": 64,
  "gcn_out_channel": 12,
  "tcn_kernel_size": 3,
  "tcn_dilation": 1,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,

  "metrics": ["MAE", "MAPE", "MSE", "RMSE", "masked_MAE", "masked_MAPE", "masked_MSE", "masked_RMSE"],

  "max_epoch": 100,
  "learner": "adam",
  "learning_rate": 0.03,
  "weight_decay": 0.0,
  "lr_decay": true,
  "lr_scheduler": "exponentiallr",
  "lr_decay_ratio": 0.95,
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 20
}
