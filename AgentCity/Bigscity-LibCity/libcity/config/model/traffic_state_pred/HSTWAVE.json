{
  "hidden_dim": 64,
  "num_layers": 3,
  "num_scales": 3,
  "num_heads": 4,
  "dropout": 0.3,
  "use_contrastive": true,
  "contrastive_weight": 0.2,
  "contrastive_temp": 0.5,
  "noise_std": 0.05,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,

  "input_window": 12,
  "output_window": 12,

  "max_epoch": 100,
  "batch_size": 1,
  "learner": "adam",
  "learning_rate": 0.001,
  "weight_decay": 0.0005,
  "lr_decay": true,
  "lr_scheduler": "steplr",
  "lr_decay_ratio": 0.5,
  "step_size": 10,
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 20
}
