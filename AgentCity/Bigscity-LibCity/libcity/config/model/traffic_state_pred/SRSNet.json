{
  "patch_len": 16,
  "stride": 8,
  "d_model": 128,
  "hidden_size": 256,
  "dropout": 0.1,
  "alpha": 2.0,
  "pos": true,
  "head_mode": "linear",
  "affine": true,
  "subtract_last": false,

  "scaler": "standard",
  "load_external": true,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": false,
  "batch_size": 8,
  "metrics": ["MAE", "MAPE", "MSE", "RMSE", "masked_MAE", "masked_MAPE", "masked_MSE", "masked_RMSE"],
  "max_epoch": 100,
  "learner": "adam",
  "learning_rate": 0.001,
  "weight_decay": 0,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.5,
  "steps": [20, 40, 60, 80],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 15
}
