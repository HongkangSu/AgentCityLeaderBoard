{
  "model": "STSSDL",

  "rnn_units": 128,
  "rnn_layers": 1,
  "cheb_k": 3,
  "prototype_num": 20,
  "prototype_dim": 64,
  "tod_embed_dim": 10,
  "node_embedding_dim": 20,
  "adaptive_embedding_dim": 48,
  "input_embedding_dim": 128,

  "cl_decay_steps": 2000,
  "use_curriculum_learning": true,
  "use_STE": true,
  "TDAY": 288,

  "lamb_c": 0.01,
  "lamb_d": 1.0,
  "contra_loss": "triplet",
  "margin": 0.5,

  "scaler": "standard",
  "load_external": true,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": true,
  "add_day_in_week": false,

  "input_window": 12,
  "output_window": 12,

  "max_epoch": 200,
  "learner": "adam",
  "learning_rate": 0.01,
  "lr_decay": true,
  "lr_scheduler": "multisteplr",
  "lr_decay_ratio": 0.1,
  "steps": [50, 100],
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 30,
  "epsilon": 0.001,
  "weight_decay": 0
}
