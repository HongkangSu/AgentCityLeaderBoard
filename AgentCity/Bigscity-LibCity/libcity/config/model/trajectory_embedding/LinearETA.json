{
    "model": "LinearETA",

    "_comment": "Downstream task: ETA (Estimated Time of Arrival) prediction",

    "_comment_model_architecture": "=== Model Architecture Parameters ===",
    "d_model": 768,
    "n_layers": 12,
    "attn_heads": 12,
    "mlp_ratio": 4,
    "dropout": 0.1,
    "drop_path": 0.1,
    "attn_drop": 0.1,
    "type_ln": "pre",
    "future_mask": false,
    "add_cls": false,
    "pooling": "mean",

    "_comment_embedding": "=== Embedding Parameters ===",
    "add_time_in_day": true,
    "add_day_in_week": true,
    "add_pe": true,

    "_comment_gat": "=== Graph Attention Network Parameters ===",
    "add_gat": true,
    "gat_heads_per_layer": [8, 1],
    "gat_features_per_layer": [16, 768],
    "gat_dropout": 0.6,
    "gat_avg_last": true,
    "load_trans_prob": false,

    "_comment_temporal": "=== Temporal Bias Parameters ===",
    "add_temporal_bias": true,
    "temporal_bias_dim": 64,
    "use_mins_interval": false,

    "_comment_training": "=== Training Parameters ===",
    "seq_len": 128,
    "batch_size": 64,
    "epochs": 50,
    "learning_rate": 0.0001,
    "weight_decay": 0.01,
    "clip_grad_norm": true,
    "max_grad_norm": 1.0,
    "patience": 10,
    "use_early_stop": true,
    "load_best_epoch": true,

    "_comment_pretrain": "=== Pre-trained Model ===",
    "load_pretrained": true,
    "pretrained_model_path": ""
}
