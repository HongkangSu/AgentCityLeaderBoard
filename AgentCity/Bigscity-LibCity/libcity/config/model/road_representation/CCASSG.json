{
  "hid_dim": 512,
  "out_dim": 512,
  "output_dim": 512,
  "n_layers": 2,
  "use_mlp": false,

  "lambd": 0.001,
  "dfr": 0.2,
  "der": 0.2,

  "scaler": "none",

  "max_epoch": 100,
  "learner": "adam",
  "learning_rate": 0.001,
  "lr_evaluator": 0.01,
  "weight_decay": 0,
  "lr_decay": true,
  "lr_scheduler": "reducelronplateau",
  "lr_decay_ratio": 0.7,
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": true,
  "patience": 50
}
